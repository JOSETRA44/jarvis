{
  "name": "jarvis",
  "version": "1.0.0",
  "description": "Remote terminal controller via WhatsApp & Telegram with web dashboard",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc --noEmit && node esbuild.config.js",
    "start": "node dist/index.js",
    "dashboard:dev": "cd dashboard && npm run dev",
    "dashboard:build": "cd dashboard && npm run build",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/infrastructure/database/migrate.ts",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/jwt": "^10.1.0",
    "@fastify/static": "^9.1.3",
    "@fastify/websocket": "^11.2.0",
    "@whiskeysockets/baileys": "^7.0.0-rc.8",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.5.0",
    "drizzle-orm": "^0.38.3",
    "fastify": "^5.1.0",
    "grammy": "^1.32.0",
    "node-pty": "^1.0.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.1.3",
    "qrcode": "^1.5.4",
    "strip-ansi": "^7.1.0",
    "uuid": "^11.0.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "@types/qrcode": "^1.5.5",
    "@types/uuid": "^10.0.0",
    "drizzle-kit": "^0.29.1",
    "esbuild": "^0.24.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
