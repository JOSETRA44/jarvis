# ============================================================
# JARVIS — Remote Terminal Controller
# Copia este archivo a .env y rellena los valores
# ============================================================

# --- Dashboard ---
DASHBOARD_PORT=3000
DASHBOARD_PASSWORD=cambia_esto_por_una_password_segura
JWT_SECRET=cambia_esto_por_un_secreto_largo_y_aleatorio_de_64chars

# --- Base de datos ---
DB_PATH=./data/jarvis.db

# --- WhatsApp ---
WA_AUTH_PATH=./data/whatsapp-auth
# 'qr' para escanear QR, 'code' para código de emparejamiento
WA_AUTH_TYPE=qr
# Solo si WA_AUTH_TYPE=code: número con código de país sin + (ej: 5215512345678)
WA_PHONE_NUMBER=

# --- Telegram ---
# Token del bot de Telegram (desde @BotFather)
TELEGRAM_BOT_TOKEN=

# --- Terminal ---
# Directorio de trabajo por defecto para ejecutar comandos
DEFAULT_CWD=C:\Users\USER
# Timeout máximo en segundos para un comando (0 = sin límite)
COMMAND_TIMEOUT_SECONDS=60
# Máximo de comandos por minuto por operador
RATE_LIMIT_PER_MINUTE=10

# --- Modo de operación inicial ---
# Opciones: ai | restricted | full-shell
INITIAL_MODE=ai

# --- Logging ---
LOG_LEVEL=info
